{
  "name": "sideui-chrome-extension",
  "version": "1.0.0",
  "description": "Chrome extension sidebar for managing favorite URLs",
  "private": true,
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html,json}\""
  },
  "devDependencies": {
    "@types/chrome": "^0.0.252",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "copy-webpack-plugin": "^11.0.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
